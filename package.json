{
  "name": "ailang-vscode",
  "displayName": "AiLang",
  "description": "Visual Studio Code support for AiLang .aos, .aiproj, and AiSVG .aisvg files.",
  "version": "0.0.2",
  "publisher": "AiLangCore",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/AiLangCore/ailang-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/AiLangCore/ailang-vscode/issues"
  },
  "homepage": "https://github.com/AiLangCore/ailang-vscode#readme",
  "keywords": [
    "ailang",
    "aivm",
    "aivectra",
    "aisvg",
    "programming-language",
    "language",
    "ai",
    "deterministic",
    "vscode-extension"
  ],
  "galleryBanner": {
    "color": "#0B1220",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ailang",
        "aliases": [
          "AiLang",
          "ailang"
        ],
        "extensions": [
          ".aos",
          ".aiproj"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "aisvg",
        "aliases": [
          "AiSVG",
          "aisvg"
        ],
        "extensions": [
          ".aisvg"
        ],
        "configuration": "./aisvg-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ailang",
        "scopeName": "source.ailang",
        "path": "./syntaxes/ailang.tmLanguage.json"
      },
      {
        "language": "aisvg",
        "scopeName": "source.aisvg",
        "path": "./syntaxes/aisvg.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ailang",
        "path": "./snippets/ailang.code-snippets"
      },
      {
        "language": "aisvg",
        "path": "./snippets/aisvg.code-snippets"
      }
    ],
    "configurationDefaults": {
      "explorer.fileNesting.enabled": true,
      "explorer.fileNesting.patterns": {
        "*.aisvg": "${capture}.aisvg.aos"
      }
    }
  }
}
